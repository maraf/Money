@if (CurrentPart == CalendarPickerPart.Year)
{
    <div class="calendar-picker">
        <div class="calendar-picker-nav">
            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="(() => CurrentYear -= 12)">
                <Icon Identifier="angle-left" />
            </button>
            <span class="calendar-picker-title">@(CurrentYear - 5) – @(CurrentYear + 6)</span>
            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="(() => CurrentYear += 12)">
                <Icon Identifier="angle-right" />
            </button>
        </div>
        <div class="calendar-picker-grid calendar-picker-grid-4">
            @for (int i = CurrentYear - 5; i <= CurrentYear + 6; i++)
            {
                var year = i;
                <button type="button" class="btn btn-sm @(Value.Year == year ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => OnYearSelected(year))">
                    @year
                </button>
            }
        </div>
    </div>
}
else if (CurrentPart == CalendarPickerPart.Month)
{
    <div class="calendar-picker">
        <div class="calendar-picker-nav">
            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="(() => CurrentYear--)">
                <Icon Identifier="angle-left" />
            </button>
            <span class="calendar-picker-title cursor-pointer" @onclick="(() => CurrentPart = CalendarPickerPart.Year)">@CurrentYear</span>
            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="(() => CurrentYear++)">
                <Icon Identifier="angle-right" />
            </button>
        </div>
        <div class="calendar-picker-grid calendar-picker-grid-4">
            @for (int i = 0; i < MonthNames.Length - 1; i++)
            {
                var month = i + 1;
                var monthName = MonthNames[i];
                <button type="button" class="btn btn-sm @(Value.Year == CurrentYear && Value.Month == month ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => OnMonthSelected(month))">
                    @monthName
                </button>
            }
        </div>
    </div>
}
else
{
    <div class="calendar-picker">
        <div class="calendar-picker-nav">
            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="PrevMonth">
                <Icon Identifier="angle-left" />
            </button>
            <span class="calendar-picker-title cursor-pointer" @onclick="(() => CurrentPart = CalendarPickerPart.Month)">
                @MonthNames[CurrentMonth - 1] @CurrentYear
            </span>
            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="NextMonth">
                <Icon Identifier="angle-right" />
            </button>
        </div>
        <MonthView TItem="int" Year="@CurrentYear" Month="@CurrentMonth" Context="day">
            <button type="button" class="btn btn-sm w-100 @DayCssClass(day)" @onclick="@(() => OnDaySelected(day))">
                @day
            </button>
        </MonthView>
        <div class="calendar-picker-footer">
            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="OnTodaySelected">
                <Icon Identifier="calendar-day" /> Today
            </button>
        </div>
    </div>
}
