@inherits ModalDialog

<Modal @ref="Modal" Title="Change an amount of the expense template">
    <ChildContent>
        <Validation ErrorMessages="@ErrorMessages" />
        <div class="mb-3">
            <label class="form-label" for="expense-template-amount">Amount:</label>
            <div class="checkbox">
                <label>
                    <input type="checkbox" @bind="IsNoAmountNorCurrency" @bind:after="OnNoAmountNorCurrencyChanged" />
                    No amount, nor currency
                </label>
            </div>
            <AmountBox Id="expense-template-amount" AutoFocus="true" AutoSelect="true" AllowEmpty="true" IsReadOnly="@IsNoAmountNorCurrency" @bind-Value="@Amount" />
        </div>
    </ChildContent>
    <Buttons>
        <button class="btn btn-primary" @onclick="@OnSaveClick">Save</button>
    </Buttons>
</Modal>
